OPENAI_API_KEY="sk-1234"
ANTHROPIC_API_KEY=""
OLLAMA=""
PROMPT_TOOLKIT_NO_CPR=1
CAI_STREAM=false
CAI_MODEL="alias1"

# OAuth Authentication (Claude Code / Codex)
# Supports OAuth credentials from Claude Code and Codex CLI tools
# CAI_AUTH_METHOD: "auto" (default) | "oauth" | "api_key"
#   - auto: Use OAuth if available, fallback to API key
#   - oauth: OAuth only (will fail if not available)
#   - api_key: API key only (ignore OAuth)
CAI_AUTH_METHOD="auto"